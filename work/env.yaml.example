# API keys for asset generation scripts
# -----------------------------------------------
# 1. Copy this file to .env.yaml:
#      cp work/env.yaml.example work/.env.yaml
# 2. Fill in your actual API keys below.
# 3. NEVER commit work/.env.yaml to git!
#    (it is already excluded via .gitignore)
# -----------------------------------------------

# OpenAI API key (used by work/images/makeImages.py and makeImages_spritesheet.py)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY: "your-openai-api-key-here"

# ElevenLabs API key (used by work/sfx/makeSFX.py)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY: "your-elevenlabs-api-key-here"
